# ============================================================
#  Variaveis de ambiente - Raizes do Nordeste API
#  Copie este arquivo para ".env" e ajuste os valores.
#  (o arquivo .env NAO deve ser versionado no Git)
# ============================================================

# Caminho do banco SQLite (arquivo local dentro de /prisma)
DATABASE_URL="file:./dev.db"

# Porta onde a API vai rodar
PORT=3000

# Segredo usado para assinar os tokens JWT.
# Em producao use um valor longo e aleatorio.
JWT_SECRET="troque-este-segredo-por-um-valor-aleatorio-e-longo"

# Tempo de expiracao do token (ex.: 1h, 8h, 7d)
JWT_EXPIRES_IN="8h"
